# Normalize line endings: the repository is LF-canonical (matches ruff format
# `line-ending = "lf"` and the `mixed-line-ending` pre-commit hook).
* text=auto eol=lf

# Explicitly LF for source + config (authoritative, avoids platform drift).
*.py    text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
Makefile text eol=lf

# Binary / generated — never normalize.
*.png   binary
*.jpg   binary
*.ico   binary
*.gz    binary
*.zip   binary
*.lock  -text
